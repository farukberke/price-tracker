# Telegram notifications. Copy to .env and fill in.
# Bot token: talk to @BotFather, /newbot, copy the token it gives you.
# Chat id:  message your bot once, then GET
#           https://api.telegram.org/bot<TOKEN>/getUpdates and read result[].message.chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets change log (optional). Appends one row per price change.
# 1. Copy a service account JSON to ./credentials/service-account.json
#    (../pet_shop_project/credentials/service-account.json works — same GCP project;
#     just enable the Sheets API for it in the Cloud console).
# 2. Create a spreadsheet, share it with the service account's client_email (Editor),
#    and put its id (the long string in the URL) below.
# 3. Optionally add a tab named "Changes" (default) or set GOOGLE_SHEET_TAB.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Changes
